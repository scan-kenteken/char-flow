#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'USAGE'
Usage: ./download [-t times] [package]

Downloads an npm package tarball from the npm registry with a fresh temporary
cache for every download, then deletes the downloaded tarball.

Examples:
  ./download
  ./download -t 10
  ./download -t 10 char-flow
USAGE
}

times=1
package_name=""

while (($#)); do
  case "$1" in
    -t|--times)
      if (($# < 2)); then
        echo "error: $1 requires a number" >&2
        exit 1
      fi
      times="$2"
      shift 2
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    -*)
      echo "error: unknown option: $1" >&2
      usage >&2
      exit 1
      ;;
    *)
      if [[ -n "$package_name" ]]; then
        echo "error: only one package name can be provided" >&2
        usage >&2
        exit 1
      fi
      package_name="$1"
      shift
      ;;
  esac
done

if ! [[ "$times" =~ ^[1-9][0-9]*$ ]]; then
  echo "error: -t must be a positive integer" >&2
  exit 1
fi

if [[ -z "$package_name" ]]; then
  package_name="$(node -p "require('./package.json').name")"
fi

for i in $(seq 1 "$times"); do
  cache_dir="$(mktemp -d)"
  work_dir="$(mktemp -d)"

  cleanup() {
    rm -rf "$cache_dir" "$work_dir"
  }
  trap cleanup RETURN

  echo "[$i/$times] downloading $package_name from npm registry"
  tarball="$(
    npm pack "$package_name" \
      --registry=https://registry.npmjs.org/ \
      --cache="$cache_dir" \
      --prefer-online \
      --force \
      --silent \
      --pack-destination="$work_dir"
  )"

  rm -f "$work_dir/$tarball"
  cleanup
  trap - RETURN
done

echo "completed $times download(s)"
